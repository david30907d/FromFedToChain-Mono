PORT=3000

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=your-bucket
R2_PUBLIC_BASE_URL=https://your-public-r2-domain

GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
GOOGLE_APPLICATION_CREDENTIALS_BASE64=

# Optional TTS overrides
GOOGLE_TTS_LANGUAGE_CODE=cmn-TW
GOOGLE_TTS_VOICE_NAME=cmn-TW-Wavenet-A

# LLM
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-3-5-sonnet-20241022
LLM_THINKING_MODEL=

# Admin-only ingest endpoint
INGEST_ADMIN_TOKEN=replace-with-a-long-random-token
